{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kmros.local/schemas/fleet-desired.schema.json",
  "title": "kmros fleet-desired contract",
  "description": "Versionerat, read-only desired-state contract for the kmros fleet. Validates control-plane/fleet-desired.yaml. Secret VALUES are forbidden; only names/identifiers are allowed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "profiles",
    "source",
    "rollout",
    "channels",
    "scheduled",
    "recovery",
    "owner_controlled",
    "updater",
    "retention",
    "secrets",
    "freshness"
  ],
  "properties": {
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "kind", "owner_decision_id"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "kind": { "type": "string", "const": "fleet-desired" },
        "owner_decision_id": { "type": "string", "minLength": 1 }
      }
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/profile"
      },
      "propertyNames": { "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lineage", "upstream_remote", "profiles"],
      "properties": {
        "lineage": { "type": "string", "minLength": 1 },
        "upstream_remote": { "type": "string", "minLength": 1 },
        "profiles": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["current_release", "previous_release"],
            "properties": {
              "current_release": { "type": "string", "minLength": 1 },
              "previous_release": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "rollout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved_divergence"],
      "properties": {
        "approved_divergence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_release_lag", "window_minutes"],
          "properties": {
            "max_release_lag": { "type": "integer", "minimum": 0 },
            "window_minutes": { "type": "integer", "minimum": 0 }
          }
        },
        "note": { "type": "string" }
      }
    },
    "channels": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonical_brief", "required_skills", "knowledge_root"],
        "properties": {
          "canonical_brief": { "type": "string", "minLength": 1 },
          "required_skills": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "knowledge_root": { "type": "string", "minLength": 1 }
        }
      }
    },
    "scheduled": {
      "type": "object",
      "additionalProperties": false,
      "required": ["launchagents", "cron"],
      "properties": {
        "launchagents": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/scheduled_entry" }
        },
        "cron": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/scheduled_entry" }
        }
      }
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checks", "global"],
      "properties": {
        "checks": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["authority", "max_attempts", "on_exhaust"],
            "properties": {
              "authority": { "type": "string", "minLength": 1 },
              "max_attempts": { "type": "integer", "minimum": 0 },
              "on_exhaust": { "type": "string", "minLength": 1 }
            }
          }
        },
        "global": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_attempts_per_hour", "on_exhaust"],
          "properties": {
            "max_attempts_per_hour": { "type": "integer", "minimum": 0 },
            "on_exhaust": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "owner_controlled": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "allowed_effects", "forbidden_effects"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "allowed_effects": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "forbidden_effects": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "updater": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages", "rollback", "drills"],
      "properties": {
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "action"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "action": { "type": "string", "minLength": 1 },
              "soak_minutes": { "type": "integer", "minimum": 0 },
              "target_profile": { "type": "string", "minLength": 1 }
            }
          }
        },
        "rollback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["conditions", "action"],
          "properties": {
            "conditions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            },
            "action": { "type": "string", "minLength": 1 }
          }
        },
        "drills": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "required"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" }
            }
          }
        }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["releases_kept", "worktrees_kept", "protected_release_classes", "protected_worktree_classes"],
      "properties": {
        "releases_kept": { "type": "integer", "minimum": 0 },
        "worktrees_kept": { "type": "integer", "minimum": 0 },
        "protected_release_classes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "protected_worktree_classes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "identifier"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "identifier": { "type": "string", "minLength": 1 }
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["last_affirmed_at", "max_age_hours"],
      "properties": {
        "last_affirmed_at": { "type": "string", "format": "date-time" },
        "max_age_hours": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "port", "required_platforms", "service_labels"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "required_platforms": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "service_labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "scheduled_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "enum": ["active", "paused", "retired"] },
        "reason": { "type": "string" },
        "schedule": { "type": "string" },
        "owner_profile": { "type": "string" }
      }
    }
  }
}