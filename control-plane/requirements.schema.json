{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes.local/requirements.schema.json",
  "title": "Reusable requirements manifest for the completion-integrity-gate (CIG)",
  "description": "Self-contained requirements manifest consumed by the reusable completion-integrity-gate. The CIG validates this manifest against the schema BEFORE any evaluation, then computes a deterministic status for every requirement. The manifest is the single semantic authority. No hardcoded REQUIREMENT_SEMANTICS table. The manifest NEVER carries an expected field — accepted outcome is derived deterministically from the check type.",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "manifest_id", "goal_id", "source_message", "requirements"],
  "properties": {
    "manifest_version": { "type": "string", "minLength": 1 },
    "manifest_id": { "type": "string", "minLength": 1 },
    "goal_id": { "type": "string", "minLength": 1,
      "description": "The goal this manifest tracks. Enforces contract rule 1." },
    "source_message": { "type": "string", "minLength": 1,
      "description": "The originating message/corpus that established the requirements." },
    "generated_by": { "type": "string" },
    "description": { "type": "string" },
    "anchors": { "type": "object", "additionalProperties": { "type": "string" } },
    "cards": {
      "type": "array",
      "description": "Optional Kanban cards. Each card must reference a requirement by ID (rule 2).",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "requirement_id", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "requirement_id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["todo", "in_progress", "done", "blocked"] }
        }
      }
    },
    "requirements": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "text", "source_hash", "check"],
        "properties": {
          "id": { "type": "string", "minLength": 1,
            "description": "Unique requirement identifier. NOT hardcoded — any non-empty string." },
          "text": { "type": "string", "minLength": 1 },
          "source_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "check": { "$ref": "#/$defs/check" }
        }
      }
    }
  },
  "$defs": {
    "check": {
      "oneOf": [
        { "$ref": "#/$defs/checks/git_ancestor" },
        { "$ref": "#/$defs/checks/git_not_ancestor" },
        { "$ref": "#/$defs/checks/file_sha256" },
        { "$ref": "#/$defs/checks/schema_valid" },
        { "$ref": "#/$defs/checks/test_receipt" },
        { "$ref": "#/$defs/checks/owner_decision_receipt" },
        { "$ref": "#/$defs/checks/all_of" }
      ]
    },
    "checks": {
      "git_ancestor": {
        "type": "object", "additionalProperties": false,
        "required": ["type", "branch", "commit_sha"],
        "properties": {
          "type": { "const": "git_ancestor" },
          "branch": { "type": "string", "minLength": 1, "maxLength": 200 },
          "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
        }
      },
      "git_not_ancestor": {
        "type": "object", "additionalProperties": false,
        "required": ["type", "branch", "commit_sha"],
        "properties": {
          "type": { "const": "git_not_ancestor" },
          "branch": { "type": "string", "minLength": 1, "maxLength": 200 },
          "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
        }
      },
      "file_sha256": {
        "type": "object", "additionalProperties": false,
        "required": ["type", "path", "expected_sha256"],
        "properties": {
          "type": { "const": "file_sha256" },
          "path": { "type": "string", "minLength": 1 },
          "expected_sha256": { "type": "string", "pattern": "^([0-9a-f]{64}|PENDING_EVIDENCE)$" }
        }
      },
      "schema_valid": {
        "type": "object", "additionalProperties": false,
        "required": ["type", "yaml_path", "schema_path"],
        "properties": {
          "type": { "const": "schema_valid" },
          "yaml_path": { "type": "string", "minLength": 1 },
          "schema_path": { "type": "string", "minLength": 1 }
        }
      },
      "test_receipt": {
        "type": "object", "additionalProperties": false,
        "required": ["type", "receipt_path", "expected_check_id"],
        "properties": {
          "type": { "const": "test_receipt" },
          "receipt_path": { "type": "string", "minLength": 1 },
          "expected_check_id": { "type": "string", "minLength": 1 }
        }
      },
      "owner_decision_receipt": {
        "type": "object", "additionalProperties": false,
        "required": ["type", "receipt_path", "owner_id"],
        "properties": {
          "type": { "const": "owner_decision_receipt" },
          "receipt_path": { "type": "string", "minLength": 1 },
          "owner_id": { "type": "string", "minLength": 1 }
        }
      },
      "all_of": {
        "type": "object", "additionalProperties": false,
        "required": ["type", "checks"],
        "properties": {
          "type": { "const": "all_of" },
          "checks": { "type": "array", "minItems": 1,
            "items": { "$ref": "#/$defs/check" } }
        }
      }
    }
  }
}
