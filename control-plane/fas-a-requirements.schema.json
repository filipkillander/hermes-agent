{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes.local/fas-a-requirements.schema.json",
  "title": "Fas A requirements manifest",
  "description": "Self-contained requirements manifest consumed by the completion-integrity-gate (CIC). The CIC computes status for every requirement; the manifest never carries a status field.",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "manifest_id", "requirements"],
  "properties": {
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_by": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "anchors": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "source_hash", "check", "expected"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^FAS-A-[0-9]{3}$",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "source_hash": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "check": {
            "type": "object",
            "additionalProperties": true,
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "git_ancestor",
                  "git_not_ancestor",
                  "file_sha256",
                  "schema_valid",
                  "test_receipt",
                  "owner_decision_receipt"
                ]
              }
            }
          },
          "expected": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}